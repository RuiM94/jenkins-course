import groovy.json.JsonSlurperClassic 

@NonCPS
def jsonParse(def json) {
    new JsonSlurperClassic().parseText(json)
}

def repo = "edwardviaene/jenkins-course"

// Use Jenkins credential (String credential with your GitHub PAT)
def githubToken = credentials('github-token-id')

// Call GitHub API
def pr = httpRequest(
    customHeaders: [[
        maskValue: true,
        name: 'Authorization',
        value: "token ${githubToken}"
    ]],
    acceptType: 'APPLICATION_JSON',
    url: "https://api.github.com/repos/${repo}/pulls"
)

// Parse response
def prData = jsonParse(pr.content)

// Print source branch names
for (p in prData) {
    println(p.head.ref)
}
